{
    "name": "pubvana/search",
    "description": "Search package for Pubvana",
    "type": "flightphp-plugin",
    "license": "MIT",
    "authors": [
        {
            "name": "enlivenapp",
            "email": "mw@enlivenapp.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "enlivenapp/flight-school": "^0.3",
        "enlivenapp/flight-settings": "^0.2"
    },
    "suggest": {
        "pubvana/admin": "Public controller base class for rendering search results",
        "pubvana/blog": "Makes blog posts searchable",
        "pubvana/pages": "Makes pages searchable"
    },
    "autoload": {
        "psr-4": {
            "Pubvana\\Search\\": "src/"
        }
    }
}
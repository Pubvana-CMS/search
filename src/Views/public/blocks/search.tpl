<div class="pv-block">
    <div class="pv-search-block">
        <form class="pv-search-block-form" action="{{ action }}" method="GET">
            <label class="pv-search-block-label" for="pv-search-block-input">{{ label }}</label>
            <input class="pv-search-block-input" type="search" id="pv-search-block-input" name="q" placeholder="{{ placeholder }}">
            <button class="pv-search-block-button" type="submit">{{ button_text }}</button>
        </form>
    </div>
</div>
